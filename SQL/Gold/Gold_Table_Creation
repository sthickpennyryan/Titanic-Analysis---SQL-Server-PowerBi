USE titanic;

SELECT * FROM silver.combined

IF OBJECT_ID('gold.fact_table', 'U') IS NOT NULL
	DROP TABLE gold.fact_table;
CREATE TABLE gold.fact_table (
		PassengerID INT PRIMARY KEY,
		Ticket VARCHAR(50),
		[Class] VARCHAR(20),
		Sex VARCHAR(20),
		Age INT,
		Fare DECIMAL(10,2),
		SibSp INT,
		Parch INT,
		[Status] INT,
		Embarked VARCHAR(50),
		AgeGroup VARCHAR(20),
		)
INSERT INTO gold.fact_table (
		PassengerID,
		Ticket,
		[Class],
		Sex,
		Age,
		Fare,
		SibSp,
		Parch,
		[Status],
		Embarked,
		AgeGroup
		)
SELECT 
		PassengerID,
		Ticket,
		CASE 
				WHEN Pclass = '1' THEN 'Upper'
				WHEN Pclass = '2' THEN 'Middle'
				ELSE 'Lower'
		END AS Class,
		Sex,
		Age,
		Fare,
		SibSp,
		Parch,
		Survived AS [Status],
		Embarked,
		CASE 
			WHEN Age <=1 THEN 'Baby'
			WHEN Age >= 1 AND Age < 4 THEN 'Toddler'
			WHEN Age >= 4 AND AGE < 13 THEN 'Child'
			WHEN Age >= 13 AND AGE < 19 THEN 'Teenager'
			ELSE 'Adult'
		END AS 'Age Group'
		FROM silver.combined

