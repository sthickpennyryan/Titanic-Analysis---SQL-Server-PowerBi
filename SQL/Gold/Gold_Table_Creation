--- I want % survived based on age group
WITH query_table AS (
	SELECT 
		COUNT(*) Total_Passengers, 
		AgeGroup,
		Status
	FROM gold.fact_table
	GROUP BY AgeGroup, Status
	--- ORDER BY AgeGroup ORDER BY DOESN'T WORK IN VIEWS BUT IT WAS THERE TO ENSURE THE DATA WAS FINE WHEN CHECKING THE SELECT ORDER BY AgeGroup;
	)
	SELECT *
	FROM (
		SELECT	
			AgeGroup,
			Status,
			Total_Passengers,
			CAST(
			ROUND((Total_Passengers * 100.0) / SUM(Total_Passengers) OVER (PARTITION BY AgeGroup), 2) AS DECIMAL(4, 2)) AS Survival_Percentage --- changed to 2.dp
	FROM query_table 
	) t
	WHERE Status = 1
	ORDER BY Survival_Percentage DESC;

