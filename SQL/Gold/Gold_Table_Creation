IF OBJECT_ID('gold.dim_pass', 'U') IS NOT NULL
	DROP TABLE gold.dim_pass;
CREATE TABLE gold.dim_pass(
		PassengerID INT PRIMARY KEY,
		Sex VARCHAR(20),
		[Class] VARCHAR(20),
		Title VARCHAR(50),
		AgeGroup VARCHAR(20),
		Surname VARCHAR(100),
		)
	INSERT INTO gold.dim_pass (
		PassengerID,
		Sex,
		[Class],
		Title,
		Surname,
		AgeGroup
		)
	SELECT 
		PassengerID,
		Sex,
		Pclass AS [Class],
		SUBSTRING(
		Name, (CHARINDEX(',', Name) + 2), 
		(CHARINDEX('.', Name) - CHARINDEX(',', Name) -2)) AS Title,
		LEFT(Name, CHARINDEX(',', Name) - 1) AS Surname,
		CASE 
			WHEN Age <=1 THEN 'Baby'
			WHEN Age >= 1 AND Age < 4 THEN 'Toddler'
			WHEN Age >= 4 AND AGE < 13 THEN 'Child'
			WHEN Age >= 13 AND AGE < 19 THEN 'Teenager'
			ELSE 'Adult'
		END AS 'Age Group'

