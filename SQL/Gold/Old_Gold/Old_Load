CREATE OR ALTER VIEW gold.vw_passenger_overall AS
	SELECT 
		f.PassengerID,
		f.[Status],
		f.[Class],
		f.Age,
		f.SibSp,
		f.Parch,
		f.Fare,
		d.Sex,
		d.Title,
		d.Surname,
		d.AgeGroup,
		f.Cabin,
		t.Embarked
	FROM gold.fact_passengers f
	LEFT JOIN gold.dim_passenger d
		ON f.PassengerID = d.PassengerID
	LEFT JOIN gold.dim_ticket t
		ON f.Ticket = t.Ticket
